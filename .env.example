# WhatsApp AI Engineer — Environment Variables

# Gemini API Key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (optional, defaults to gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Claude Code binary path (auto-detected)
# CLAUDE_BIN=/home/ubuntu/.local/bin/claude

# Allowed WhatsApp phone numbers (comma-separated, with country code, no +)
# Leave empty to allow ALL numbers
ALLOWED_PHONES=

# Workspace and Knowledge Base
# Default working directory for Claude Code sessions
DEFAULT_WORKING_DIR=/home/ubuntu

# If provided, the start.sh script will automatically clone/pull this repo on startup
# Example: GITHUB_KB_URL=https://github.com/your-org/knowledge-base.git
GITHUB_KB_URL=

# The directory where the Knowledge Base will be stored & referenced by Claude
KB_DIR=./kb

# Paths
AUTH_DIR=./auth_info
DB_PATH=./sessions.db
LOG_DIR=./logs
